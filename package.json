    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.10",
    "expo-print": "~14.0.3",
    "expo-router": "~4.0.22",
